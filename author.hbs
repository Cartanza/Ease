{{#*inline "body"}}
<main class="site-main">

    {{#with author}}
    <div class="term-container gh-canvas">
        <section class="term">
            {{#if profile_image}}
                <img class="term-image" src="{{img_url profile_image size="xs"}}" alt="{{name}}">
            {{/if}}
            <h1 class="term-name">{{name}}</h1>
            {{#if bio}}
                <div class="term-description">{{bio}}</div>
            {{/if}}
        </section>
    </div>
    {{/with}}

    <div class="post-feed gh-canvas">
        {{#foreach posts}}
            {{> partials/loop}}
        {{/foreach}}
    </div>

    {{pagination}}

</main>
{{/inline}}
{{> default}}