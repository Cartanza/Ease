{{#*inline "body"}}
{{#with post}}

<main class="site-main">
    <article class="{{post_class}}">

        {{#match show_title_and_feature_image}}
            <header class="gh-article-header gh-canvas">
                <h1 class="gh-article-title">{{title}}</h1>
                {{> partials/post-image}}
            </header>
        {{/match}}

        <div class="post-content gh-content gh-canvas">
            {{{content}}}
        </div>

    </article>
</main>

{{/with}}
{{/inline}}
{{> default}}