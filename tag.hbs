{{#*inline "body"}}
<main class="site-main">

    {{#with tag}}
    <div class="term-container gh-canvas">
        <section class="term">
            <h1 class="term-name">{{name}}</h1>
            {{#if description}}
                <div class="term-description">{{description}}</div>
            {{/if}}
        </section>
    </div>
    {{/with}}

    <div class="post-feed gh-canvas">
        {{#foreach posts}}
            {{> partials/loop}}
        {{/foreach}}
    </div>

    {{pagination}}

</main>
{{/inline}}
{{> default}}